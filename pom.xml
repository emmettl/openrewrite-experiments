<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>io.github.emmettl</groupId>
  <artifactId>openrewrite-experiments</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>openrewrite-experiments</name>
  <description>A playground for custom OpenRewrite recipes.</description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>17</maven.compiler.release>
    <!--
      The only OpenRewrite version in this file. rewrite-recipe-bom is a superset of rewrite-bom:
      it manages rewrite-core/java/test AND the published recipe modules (rewrite-static-analysis,
      rewrite-migrate-java, ...), so recipes here can compose with those without adding versions.
    -->
    <rewrite-recipe-bom.version>3.35.0</rewrite-recipe-bom.version>
    <!-- Must match the Jupiter API rewrite-test compiles against, or the engine and API disagree. -->
    <junit.version>5.13.2</junit.version>
    <assertj.version>3.27.3</assertj.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.junit</groupId>
        <artifactId>junit-bom</artifactId>
        <version>${junit.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <!-- Pins rewrite-core/java/test AND the third-party recipe modules to one compatible set. -->
      <dependency>
        <groupId>org.openrewrite.recipe</groupId>
        <artifactId>rewrite-recipe-bom</artifactId>
        <version>${rewrite-recipe-bom.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>org.openrewrite</groupId>
      <artifactId>rewrite-java</artifactId>
    </dependency>

    <!-- Test harness: RewriteTest + the assertion DSL. -->
    <dependency>
      <groupId>org.openrewrite</groupId>
      <artifactId>rewrite-test</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Source: https://mvnrepository.com/artifact/org.mockito/mockito-core -->
    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-core</artifactId>
      <version>5.23.0</version>
      <scope>test</scope>
    </dependency>
    <!--
      The parser that turns test source into an LST. It drives the JDK's own javac internals, so it
      must match the JDK the tests run on — hence rewrite-java-25 and a CI pinned to 25. Add
      rewrite-java-17/-21 alongside it if you want tests that parse at those language levels.
    -->
    <dependency>
      <groupId>org.openrewrite</groupId>
      <artifactId>rewrite-java-25</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <version>${assertj.version}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <!--
            Required by OpenRewrite. Recipe options are deserialized by Jackson using the *names* of
            the constructor parameters, which only survive into the bytecode with this flag. Without
            it, a recipe that takes options fails when it is loaded, not when it is compiled.
          -->
          <parameters>true</parameters>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.5.2</version>
        <configuration>
          <!--
            The fixtures package is recipe *input*, not a suite to execute. Those classes are
            compiled so that both sides of a migration are known to be valid Java, and so their
            types are available to the parser — but running them is meaningless, since nothing
            wires up their mocks.
          -->
          <excludes>
            <exclude>**/fixtures/**</exclude>
          </excludes>
          <!--
            The Java parser drives javac internals directly, so the test JVM has to open them.
            Without these you get IllegalAccessError from com.sun.tools.javac.* at parse time.
          -->
          <argLine>
            --add-exports jdk.compiler/com.sun.tools.javac.api=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.file=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.main=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.model=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.tree=ALL-UNNAMED
            --add-exports jdk.compiler/com.sun.tools.javac.util=ALL-UNNAMED
            --add-opens jdk.compiler/com.sun.tools.javac.code=ALL-UNNAMED
            --add-opens jdk.compiler/com.sun.tools.javac.comp=ALL-UNNAMED
          </argLine>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
